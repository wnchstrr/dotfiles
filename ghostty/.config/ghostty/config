# Тема 
theme = TokyoNight Storm 

# ANSI palette overrides (Tokyonight Storm tweaks)
palette = 2=#3b8e9e     # green (cava, git added)
palette = 10=#3b8e9e    # bright green
palette = 3=#bb9af7     # WARNING — yellow->magenta (эстетика, не семантика!)
palette = 11=#bb9af7    # bright yellow (Gtk-WARNING) -> magenta

# Shaders
custom-shader = shaders/cursor_blaze.glsl
custom-shader-animation = true

# Шрифт
font-family = "Cascadia Mono NF"
font-size = 19

# Окно
window-padding-x = 8
window-padding-y = 8
window-padding-color = extend
window-save-state = always
window-decoration = false

# Курсор
cursor-style = bar
cursor-style-blink = true

# Отменить дефолтные alt+цифры (конфликт с Hyprland Alt-мод)
keybind = alt+one=unbind
keybind = alt+two=unbind
keybind = alt+three=unbind
keybind = alt+four=unbind
keybind = alt+five=unbind
keybind = alt+six=unbind
keybind = alt+seven=unbind
keybind = alt+eight=unbind
keybind = alt+nine=unbind

# Свои вкладки на ctrl+цифры
keybind = ctrl+one=goto_tab:1
keybind = ctrl+two=goto_tab:2
keybind = ctrl+three=goto_tab:3
keybind = ctrl+four=goto_tab:4
keybind = ctrl+five=goto_tab:5
keybind = ctrl+six=goto_tab:6
keybind = ctrl+seven=goto_tab:7
keybind = ctrl+eight=goto_tab:8
keybind = ctrl+nine=last_tab

# Создание сплитов
keybind = ctrl+shift+e=new_split:right
keybind = ctrl+shift+d=new_split:down
keybind = ctrl+shift+x=close_surface

# навигация между сплитами
keybind = ctrl+shift+left=goto_split:left
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+up=goto_split:top
keybind = ctrl+shift+down=goto_split:bottom
unfocused-split-opacity = 0.7

# SSH (важно для серверов — авто terminfo)
shell-integration = detect
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo

# Удобства
mouse-hide-while-typing = true
clipboard-paste-protection = true
clipboard-trim-trailing-spaces = true
confirm-close-surface = true
background-opacity = 0.88
copy-on-select = clipboard

# Quick Terminal
keybind = global:ctrl+grave_accent=toggle_quick_terminal
quick-terminal-animation-duration = 0.2
quick-terminal-position = top
quick-terminal-autohide = true

